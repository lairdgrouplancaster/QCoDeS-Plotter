{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        
        "GUI": {
            "type": "object",
            "properties": {
                "plot_frame_fraction": {
                    "type": "number",
                    "exclusiveMinimum": 0,
                    "exclusiveMaximum": 1,
                    "default": 0.47
                },
                "main_frame_size": {
                    "type": "array",
                    "items": { "type": "integer"},
                    "minItems": 2,
                    "maxItems": 2,
                    "default": [600, 700]
                },
                "preview_size": {
                    "type": "integer",
                    "minimum": 50,
                    "maximum": 1000,
                    "default": 200
                }
            },
            "required": ["plot_frame_fraction", "main_frame_size"],
            "additionalProperties": false
        },
        
        "file": {
            "type": "object",
            "properties": {
                "default_load_path": {
                    "type": "string",
                    "default": ""
                },
                "last_file_path": {
                    "type": "string",
                    "default": ""
                },
                "recent_file_paths": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": []
                }
            },
            "required": ["default_load_path", "last_file_path"],
            "additionalProperties": false
        },
        
        "user_preference": {
            "type": "object",
            "properties": {
                "theme":{
                    "type": "string",
                    "enum": ["light", "dark", "pyqt"],
                    "default": "light"
                },
                "bar_colour" : {
                    "type": "string",
                    "default": "viridis"
                },
                "bar_colour_include_cet": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_matplotlib": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_local": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_custom": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_cet_linear": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_cet_divergent": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_cet_cyclic": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_cet_rainbow": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_cet_isoluminant": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_cet_other": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_matplotlib_perceptual": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_matplotlib_sequential": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_matplotlib_divergent": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_matplotlib_cyclic": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_matplotlib_qualitative": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_include_matplotlib_other": {
                    "type": "boolean",
                    "default": true
                },
                "bar_colour_excluded": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": []
                },
                "bar_colour_excluded_prefixes": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": []
                },
                "confirm_close": {
                    "type": "boolean",
                    "default": true
                },
                "confirm_close_all": {
                    "type": "boolean",
                    "default": true
                },
                "auto_plot": {
                    "type": "boolean",
                    "default": false
                },
                "default_refresh_rate": {
                    "type": "number",
                    "minimum": 0,
                    "default": 1
                }
            },
            "required": ["theme", "bar_colour", "confirm_close", "default_refresh_rate"],
            "additionalProperties": false
        },
        
        "runtime_settings": {
            "type": "object",
            "properties": {
                "max_threads": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 4
                },
                "del_grace_period": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 300,
                    "default": 10
                },
                "cloud_sync_timeout": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 3600,
                    "default": 120
                }
             },
             "required": ["max_threads", "del_grace_period", "cloud_sync_timeout"],
             "additionalProperties": false 
        }
    },
    "required": ["GUI", "file", "user_preference", "runtime_settings"],
    "additionalProperties": false
}
